---
import '@/styles/main.css'
import { Image } from 'astro:assets'

import type { ComponentProps } from 'astro/types'
import { SEO } from 'astro-seo'

import Footer from '@/components/Footer.astro'
import Nav from '@/components/Nav.astro'
import ToTop from '@/components/ToTop.astro'
import { config } from '@/config'
import logo from '@/images/logo.svg'

type SEOProps = ComponentProps<typeof SEO>
type OpenGraphProps = NonNullable<SEOProps['openGraph']>
export type Props = Omit<SEOProps, 'openGraph'> & {
  openGraph?: Partial<Omit<OpenGraphProps, 'basic'>> & {
    basic?: Partial<OpenGraphProps['basic']>
  }
}

const {
  title = '',
  description = config.siteMetadata.description,
  ...props
} = Astro.props
const { pathname } = Astro.url
const LogoElement = pathname === '/' ? 'h1' : 'span'

const siteOrigin = Astro.site?.origin ?? ''
const defaultOGPBasic: OpenGraphProps['basic'] = {
  title: title || config.siteMetadata.name,
  type: 'website',
  image: `${siteOrigin}/ogp.png`,
  url: siteOrigin + pathname,
}
const seoProps: SEOProps = {
  ...props,
  title: title || undefined,
  titleTemplate: props.titleTemplate ?? `%s - ${config.siteMetadata.name}`,
  titleDefault: props.titleDefault ?? config.siteMetadata.name,
  description,
  canonical: props.canonical ?? siteOrigin + pathname,
  openGraph: {
    ...props.openGraph,
    basic: {
      ...defaultOGPBasic,
      ...props.openGraph?.basic,
    },
    optional: {
      siteName: config.siteMetadata.name,
      ...props.openGraph?.optional,
    },
  },
  twitter: {
    card: 'summary_large_image',
    site: siteOrigin,
    creator: '@Pgathering315',
    title,
    image: `${siteOrigin}/ogp-lg.png`,
    ...props.twitter,
  },
}
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <SEO {...seoProps} />
  </head>
  <body class="bg-plaid">
    <div class="">
      <slot name="first-view" />
    </div>
    <div class="@container mx-auto max-w-screen-2xl overflow-x-clip">
      <div
        class="max-grail:mt-10 grail:grid-cols-[1fr_var(--spacing-main)_1fr] relative grid grid-flow-dense items-start gap-y-10">
        <LogoElement
          class="grail:sticky grail:top-0 grail:translate-y-[calc(50vh-50%)] grail:p-[3cqi]">
          <a href="/">
            <Image
              src={logo}
              alt={config.siteMetadata.name}
              class="mx-auto w-3xs"
            />
          </a>
        </LogoElement>
        <div
          class="grail:sticky grail:top-0 grail:-col-end-1 grail:translate-y-[calc(50vh-50%)] max-grail:z-10">
          <Nav />
        </div>
        <main
          class="min-h-screen bg-white px-[clamp(--spacing(5),3cqi,--spacing(10))] py-10">
          <slot />
        </main>
        <Footer class="grail:col-start-2" />
        <ToTop class="grail:-col-end-1" />
      </div>
    </div>
  </body>
</html>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    // ページ内リンクのスムーススクロール
    const anchorLinks = document.querySelectorAll('a[href*="#"]')
    for (const element of Array.from(anchorLinks)) {
      element.addEventListener('click', (event) => {
        handleClick(event)
      })
    }
  })

  const scrollToTarget = (element: HTMLElement) => {
    const isPrefersReduced = window.matchMedia(
      '(prefers-reduced-motion: reduce)'
    ).matches
    const behavior = isPrefersReduced ? 'instant' : 'smooth'

    element.scrollIntoView({ behavior })
  }

  const focusTarget = (element: HTMLElement) => {
    element.focus({ preventScroll: true })
    if (document.activeElement !== element) {
      element.setAttribute('tabindex', '-1')
      element.focus({ preventScroll: true })
    }
  }

  const handleClick = (event: Event) => {
    if (!(event instanceof MouseEvent) || event.button !== 0) return

    const clickTarget = event.target
    if (!(clickTarget instanceof Element)) return

    const currentLink = clickTarget.closest<HTMLAnchorElement>('a[href*="#"]')
    if (!currentLink) return

    const hash = currentLink.hash
    if (
      !hash ||
      currentLink.getAttribute('role') === 'tab' ||
      currentLink.getAttribute('role') === 'button' ||
      currentLink.getAttribute('data-smooth-scroll') === 'disabled'
    ) {
      return
    }

    const targetId = decodeURIComponent(hash.slice(1))
    const targetElement =
      (document.getElementById(targetId) as HTMLElement | null) ||
      ((hash === '#top' && document.body) as HTMLElement | false)
    if (targetElement instanceof HTMLElement) {
      event.preventDefault()

      scrollToTarget(targetElement)
      focusTarget(targetElement)

      if (!(hash === '#top')) {
        history.pushState({}, '', hash)
      }
    }
  }
</script>
