---
import type { HTMLAttributes } from 'astro/types'
import { twMerge } from 'tailwind-merge'
import type { VariantProps } from 'tailwind-variants'
import { tv } from 'tailwind-variants'

export const headingVariants = tv({
  base: 'font-bold',
  variants: {
    level: {
      '1': 'text-2xl',
      '2': 'text-xl',
      '3': 'text-lg',
      '4': 'text-base',
      '5': 'text-sm',
      '6': 'text-xs',
    },
  },
})

export type Props = VariantProps<typeof headingVariants> &
  HTMLAttributes<'h1' | 'h2' | 'h3' | 'h4' | 'h5' | 'h6'>

const { level = '2', class: className } = Astro.props
const Element = `h${level}` as 'h1' | 'h2' | 'h3' | 'h4' | 'h5' | 'h6'
---

<Element class={twMerge(headingVariants({ level }), className)}>
  <slot />
</Element>
