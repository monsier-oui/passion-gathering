---
import { ArrowRightIcon } from '@heroicons/react/24/outline'
import { twMerge } from 'tailwind-merge'

import Button from '@/components/Button.astro'
import { config } from '@/config'

const { class: className } = Astro.props
---

<Button
  href={config.entry}
  size="lg"
  class={twMerge(
    'w-fit border-4 border-white transition-[scale,box-shadow] duration-500 hover:scale-105 hover:shadow',
    className
  )}>
  <span class="grid px-2">
    <span class="text-xs font-medium">
      SideMが"すきー"な方なら<br />どなたでも参加OK！
    </span>
    <span class="mt-1 leading-tight font-bold">
      <span class="text-xs">サークル参加締切</span><br />
      <span class="text-2xl font-black">6/4</span>
      <span class="text-sm">まで</span>
    </span>
  </span>
  <span
    class="grid aspect-square h-auto w-fit place-content-center place-items-center gap-y-2 border-l border-current px-4 pt-5 pb-3">
    <span class="text-sm font-bold">サークル<br />参加する</span>
    <ArrowRightIcon className="size-8 stroke-3" />
  </span>
</Button>
