---
import { Image } from 'astro:assets'

import { twMerge } from 'tailwind-merge'

import CTA from '@/components/CTA.astro'
import hero from '@/images/hero.jpg'
import logo from '@/images/logo.svg'
---

<div
  class="js-trigger-totop relative mx-auto place-content-center overflow-clip">
  <Image
    src={hero}
    format="webp"
    alt=""
    width={hero.width}
    height={hero.height}
    widths={[1080, 1280, 2560, hero.width]}
    sizes={`(min-width: 640px) 1280px, (min-width: 1280px) 2560px, (min-width: ${hero.width / 2}px) ${hero.width}px, min(100vw, 640px)`}
    loading="eager"
    fetchpriority="high"
    class="mx-auto h-screen w-full object-cover sm:aspect-35/25 sm:h-auto"
  />
  <div
    class="absolute inset-0 grid h-full grid-rows-[auto_1fr_auto] sm:contents">
    <Image
      src={logo}
      alt=""
      loading="eager"
      fetchpriority="high"
      class="w-[40cqi] p-3 sm:absolute sm:top-0 sm:left-0 sm:w-[min(20cqi,var(--container-3xs))]"
    />
    <div
      id="sd-random"
      class="@container relative w-full max-sm:mt-[10%] sm:absolute sm:inset-0 sm:m-auto sm:aspect-3/4 sm:h-full sm:w-auto">
      {
        Array.from({ length: 3 }).map((_, i) => (
          <div
            class={twMerge(
              'absolute aspect-square h-auto w-[clamp(150px,40cqi,250px)]',
              i === 0 && 'top-1/12 left-[2cqi] -rotate-16',
              i === 1 && 'top-1/2 right-[-2cqi] -translate-y-1/4',
              i === 2 && 'bottom-1/12 left-[-2cqi] rotate-16'
            )}>
            <div
              class="animate-pitter-patter"
              style={{ animationDelay: `${i * 100}ms` }}>
              <img
                alt=""
                class="animate-swaying"
                style={{ animationDelay: `${(i % 3) * 100}ms` }}
              />
            </div>
          </div>
        ))
      }
    </div>
    <CTA
      class="max-sm:m-4 max-sm:justify-self-center sm:absolute sm:right-4 sm:bottom-4"
    />
  </div>
</div>

<script>
  async function showRandomSdImages() {
    const res = await fetch('/sd-images.json')
    if (!res.ok) return

    const urls = (await res.json()) as string[]
    const count = Math.min(3, urls.length)
    if (count === 0) {
      document.getElementById('sd-random')?.style.setProperty('display', 'none')
      return
    }
    const shuffled = [...urls].sort(() => Math.random() - 0.5)
    const picked = shuffled.slice(0, count)
    document.querySelectorAll('#sd-random img').forEach((el, i) => {
      if (el instanceof HTMLImageElement) {
        if (picked[i]) {
          el.src = picked[i]
          el.alt = ''
        }
      }
    })
  }
  showRandomSdImages()
</script>
