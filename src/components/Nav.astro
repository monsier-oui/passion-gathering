---
import { Image } from 'astro:assets'

import { Bars3Icon, XMarkIcon } from '@heroicons/react/24/solid'

import { config } from '@/config'

const { menu, social } = config
---

<div x-data="nav()">
  <nav
    id="nav-menu"
    class="bg-gray-200 px-5 py-12 transition-[opacity,visibility] transition-discrete aria-hidden:invisible aria-hidden:opacity-0 max-sm:fixed max-sm:inset-0 sm:px-8"
    aria-label="ナビゲーションメニュー"
    x-bind:aria-hidden="!isOpen"
    aria-hidden="true"
    x-bind:data-scroll-lock="isOpen">
    <ul class="">
      {
        menu.map(({ label, href }) => (
          <li class="">
            {href && (
              <a href={href} class="block py-2">
                {label}
              </a>
            )}
          </li>
        ))
      }
    </ul>
    <ul
      class="mt-4 grid grid-cols-[repeat(auto-fill,calc(var(--spacing)*10))] gap-x-2">
      {
        social.map(({ label, href, src }) => (
          <li>
            <a
              href={href}
              aria-label={label}
              class="block aspect-square h-auto w-full rounded-sm">
              <Image src={src} alt="" class="size-full object-contain" />
            </a>
          </li>
        ))
      }
    </ul>
  </nav>
  <button
    type="button"
    x-on:click="isOpen = !isOpen"
    x-bind:aria-expanded="isOpen"
    aria-controls="nav-menu"
    aria-label="isOpen ? 'メニューを閉じる' : 'メニューを開く'"
    class="group fixed top-0 right-0 grid size-12 cursor-pointer place-content-center lg:hidden">
    <Bars3Icon className="size-7.5 group-aria-expanded:hidden" />
    <XMarkIcon className="hidden size-7.5 group-aria-expanded:block" />
  </button>
</div>

<script is:inline>
  window.nav = function () {
    return {
      isOpen: false,
      init() {
        const root = document.documentElement
        const breakpoint = getComputedStyle(root)
          .getPropertyValue('--breakpoint-sm')
          .trim()
        const mediaQuery = window.matchMedia(`(min-width: ${breakpoint})`)
        const setMenuVisibility = (mediaQuery) => {
          this.isOpen = mediaQuery.matches
        }
        mediaQuery.addEventListener('change', setMenuVisibility)
        setMenuVisibility(mediaQuery)

        if (!mediaQuery.matches) {
          this.$nextTick(() => {
            const anchors = document.querySelectorAll('#nav-menu a')
            for (const anchor of anchors) {
              anchor.addEventListener('click', () => {
                this.isOpen = false
              })
            }
          })
        }
      },
    }
  }
</script>
