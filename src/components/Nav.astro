---
import { Image } from 'astro:assets'

import { Bars3Icon, XMarkIcon } from '@heroicons/react/24/solid'

import { config } from '@/config'

const { menu, social } = config
---

<div x-data="nav()">
  <nav
    id="nav-menu"
    class="max-grail:fixed max-grail:inset-0 grail:px-8 max-grail:transition-[opacity,translate,visibility] max-grail:transition-discrete max-grail:duration-500 bg-white px-5 py-12 aria-hidden:invisible aria-hidden:-translate-y-full aria-hidden:opacity-0"
    aria-label="ナビゲーションメニュー"
    x-bind:aria-hidden="!isOpen"
    aria-hidden="true"
    x-bind:data-scroll-lock="isOpen">
    <ul class="">
      {
        menu.map(({ label, href, items }) => (
          <li class="">
            {href && (
              <Fragment>
                <a href={href} class="block py-2">
                  {label}
                </a>
                {items && items.length > 0 && (
                  <ul class="ml-4">
                    {items.map(({ label, href }) => (
                      <li class="">
                        <a href={href} class="block py-2">
                          {label}
                        </a>
                      </li>
                    ))}
                  </ul>
                )}
              </Fragment>
            )}
          </li>
        ))
      }
    </ul>
    <ul class="mt-4 flex flex-wrap gap-2">
      {
        social.map(({ label, href, src }) => (
          <li>
            <a href={href} aria-label={label} class="block aspect-square w-10">
              <Image src={src} alt="" class="size-full object-contain" />
            </a>
          </li>
        ))
      }
    </ul>
  </nav>
  <button
    type="button"
    x-on:click="isOpen = !isOpen"
    x-bind:aria-expanded="isOpen"
    aria-controls="nav-menu"
    aria-label="isOpen ? 'メニューを閉じる' : 'メニューを開く'"
    class="group grail:hidden fixed top-0 right-0 grid size-12 cursor-pointer place-content-center">
    <Bars3Icon className="size-7.5 group-aria-expanded:hidden" />
    <XMarkIcon className="hidden size-7.5 group-aria-expanded:block" />
  </button>
</div>

<script is:inline>
  window.nav = function () {
    return {
      isOpen: false,
      init() {
        const root = document.documentElement
        const breakpoint = getComputedStyle(root)
          .getPropertyValue('--breakpoint-grail')
          .trim()
        const mediaQuery = window.matchMedia(`(min-width: ${breakpoint})`)
        const setMenuVisibility = (mediaQuery) => {
          this.isOpen = mediaQuery.matches
        }
        mediaQuery.addEventListener('change', setMenuVisibility)
        setMenuVisibility(mediaQuery)

        if (!mediaQuery.matches) {
          this.$nextTick(() => {
            const anchors = document.querySelectorAll('#nav-menu a')
            for (const anchor of anchors) {
              anchor.addEventListener('click', () => {
                this.isOpen = false
              })
            }
          })
        }
      },
    }
  }
</script>
